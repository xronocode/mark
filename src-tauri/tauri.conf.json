{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mark",
  "version": "0.0.2-test",
  "identifier": "com.xronocode.mark",
  "build": {
    "frontendDist": "../src/renderer/dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mark",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ipc://localhost; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'none'; worker-src 'self' blob:",
      "freezePrototype": false,
      "dangerousDisableAssetCspModification": false,
      "assetProtocol": {
        "enable": false,
        "scope": []
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xronocode/mark/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQUZCOTYzQUI2QTM3N0YKUldSL04ycXJZN212LzVuak9nWFhDdW9LeE9WQnZNeGN1WkFDVEVJV3V4V2RzLzluQzB3ZlZoSWoK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
